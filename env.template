# Copy this file to .env.local and fill in your API keys

# Clerk Authentication (Get from https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex Database (Will be auto-filled by 'npx convex dev')
